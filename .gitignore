# Virtual environment
.venv/
venv/
env/

# Byte-compiled / cached Python
__pycache__/
*.py[cod]
*$py.class

# SQLite database files (local deal data — never commit)
*.db
*.sqlite
*.sqlite3

# Secrets / environment variables (e.g. RentCast API key in Phase 5)
.env
.streamlit/secrets.toml

# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/

# Test / coverage artifacts
.pytest_cache/
.coverage
htmlcov/

# Editor / IDE
.vscode/
.idea/
*.swp

# macOS
.DS_Store

# Claude Code local settings (machine-local; shared settings.json stays tracked)
.claude/settings.local.json
